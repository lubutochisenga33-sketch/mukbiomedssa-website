# ─────────────────────────────────────────────
#  MUK-BIOMEDSSA  –  .gitignore
# ─────────────────────────────────────────────

# ── Environment / Secrets ─────────────────────
.env
.env.local
.env.*.local

# ── Dependencies ──────────────────────────────
node_modules/

# ── State data (generated at runtime) ─────────
data/state.json
data/*.json

# ── Logs ──────────────────────────────────────
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ── OS files ──────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
Thumbs.db
ehthumbs.db

# ── Editor / IDE ──────────────────────────────
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# ── Build output ──────────────────────────────
dist/
build/

# ── Misc ──────────────────────────────────────
.nyc_output/
coverage/
.cache/
