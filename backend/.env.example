# Copy this to .env for local development – never commit .env to GitHub

# Cloudinary (get from cloudinary.com dashboard → Settings → API Keys)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Cloudinary folder name for all MUK-BIOMEDSSA files
CLOUDINARY_FOLDER=muk-biomedssa

# Admin login for admin.html
ADMIN_USERNAME=admin
ADMIN_PASSWORD=biomedssa2025

# Port (Render sets this automatically – don't change for production)
PORT=3000
